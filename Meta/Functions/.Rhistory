mutate(rel_period = ifelse(rel_period != "Realised" & Items == "I1", NA, rel_period)) %>%
filter(!is.na(rel_period))
if (!is.null(bank)) {
bank_id = unique(data[data$Name == bank, "Bank_ID"]$Bank_ID)
data <- data %>% filter(Bank_ID == bank_id)
# if(is.null(input_ratio)){
#   rtdate = paste(lubridate::month(as.yearmon(paste0(na.omit(data$rat_date)[1], "01"), format = "%Y%m%d"), label = T, abbr = F), lubridate::year(as.yearmon(paste0(na.omit(data$rat_date)[1], "01"), format = "%Y%m%d")))
#   caption = paste0("REAs: Risk exposure amounts. Starting point: ", rtdate, " (EBA Transparency Exercise).")
# }
} else if (!is.null(iso)) {
data <- data %>%
filter(Country == iso) %>%
filter(Included == T) %>%
dplyr::select(-Bank_ID, -Name) %>%
group_by(ISO2, Items, rel_period) %>%
mutate(Amount = mean(Amount, na.rm = T)) %>%
ungroup() %>%
mutate(rat_date = NA) %>%
distinct()
}else if (is.null(iso) & is.null(bank)){
data<- data %>%
filter(Included %in% c(NA, TRUE)) %>%
dplyr::select(-Bank_ID, -Name, -ISO2, -Country, -Included) %>%
group_by(Items, rel_period) %>%
mutate(Amount = mean(Amount, na.rm = T)) %>%
ungroup() %>%
mutate(rat_date = NA) %>%
distinct()
}
depletion_results_est = data %>%
filter(Items %in% c("I1", "I11"),
rel_period %in% c("Realised", str_remove_all(period, "\\s{0,}"))
) %>%
pivot_wider(names_from = Items, values_from = Amount) %>%
group_by(ISO2, Bank_ID) %>%
mutate(I11 = dplyr::lag(I11)) %>%
ungroup() %>%
mutate(depletion = (I11-I1)) %>%
dplyr::select(-c(I1, I11, rat_date, Country, Included)) %>%
pivot_longer(-c(ISO2, Name, Bank_ID, rel_period, ), names_to = "Item", values_to = "Depletion") %>%
dplyr::select(-Item) %>%
filter(!is.na(Depletion)) %>%
mutate(Period = "Transitional") %>%
dplyr::select(Name, Period, Item, Depletion) %>%
rename(Constituent = Name, Status = Item)
return(depletion_results_est)
}
generate_tr_chart_res <- function(data, exercise, period, scenario, palette, bank = NULL, iso = NULL, font_name) {
# data = original_data_tr
# exercise = 2025
# period = "Year 1"
# scenario = "Adverse"
# bank = "Erste Group"
# iso = "AT"
# palette = c("Total" = "#5599d8", "Increase" = "#ffd966", "Decrease" = "#cc0000")
# font_name = "Kohinoor Bangla"
fact=1
dimensions_tr <- list(
"I3", "I4", "I4.1", "I4.2", "I4.3",
"I5", "I6", "I7", "I8", "I9", "I10", "I11"
)
names(dimensions_tr) <- c(
"CET1 Capital Ratio - Transitional - Restated",
"Net Profit and Losses", "Of Which Net Interest Income", "Of Which NFCI",
"Of Which Other Income/Expenses", "Credit Risk Losses", "Market Risk Losses",
"Other Comprehensive Income", "Dividends",
"Increase in REAs", "Other Items", "CET1 Capital Ratio - Transitional - End"
)
if (!is.null(bank)) {
bank_id = unique(data[data$Name == bank, "Bank_ID"]$Bank_ID)
data <- data %>% filter(Bank_ID == bank_id)
} else if (!is.null(iso)) {
data <- data %>% filter(ISO2 == iso)
}
data = data %>%
filter(!Items %in% c("I1", "I2"))
if(exercise %in% c(2018, 2025)){
dt <- data %>%
filter(
Exercise == exercise,
rel_period %in% c("Realised", str_remove_all(period, "\\s{0,}")),
Scenario %in% c("Actual", scenario)
) %>%
mutate(Amount_out = ifelse(!(Items %in% c("I4.1", "I4.2", "I4.3")), Amount, 0)) %>%
mutate(Amount_in = ifelse(Items %in% c("I3", "I4.1", "I4.2", "I4.3"), Amount, 0)) %>%
mutate(end = ifelse(!(Items %in% c("I11")), cumsum(Amount_out), 0)) %>%
mutate(end = ifelse(Items %in% c("I4.1", "I4.2", "I4.3"), cumsum(Amount_in), end)) %>%
mutate(start = ifelse(!Items %in% c("I1", "I3"), dplyr::lag(end, 1), 0)) %>%
mutate(start = ifelse(Items %in% c("I4.1"), dplyr::lag(start, 1), start)) %>%
mutate(id = as.numeric(rownames(.))) %>%
mutate(sign = ifelse(Items %in% c("I1", "I3", "I11"), "Total",
ifelse(sign(Amount) >= 0, "Increase", "Decrease"))) %>%
mutate(ofwhich = ifelse(str_detect(Items, "\\."), 1, 0)) %>%
arrange(desc(id)) %>%
mutate(stand = ifelse(sign(Amount) >= 0, end+fact, start+fact)) %>%
mutate(stand = ifelse(Items == "I11", Amount+fact, stand)) %>%
mutate(Items = factor(Items, rev(dimensions_tr), labels = rev(names(dimensions_tr))))
}else{
dt <- data %>%
filter(
Exercise == exercise,
rel_period %in% c("Realised", str_remove_all(period, "\\s{0,}")),
Scenario %in% c("Actual", scenario)
) %>%
mutate(Amount_out = ifelse(!(Items %in% c("I4.1", "I4.2", "I4.3")), Amount, 0)) %>%
mutate(Amount_in = ifelse(Items %in% c("I3", "I4.1", "I4.2", "I4.3"), Amount, 0)) %>%
mutate(end = ifelse(!(Items %in% c("I11")), cumsum(Amount_out), 0)) %>%
mutate(end = ifelse(Items %in% c("I4.1", "I4.2", "I4.3"), cumsum(Amount_in), end)) %>%
mutate(start = ifelse(!Items %in% c("I1", "I3"), dplyr::lag(end, 1), 0)) %>%
mutate(start = ifelse(Items %in% c("I4.1"), dplyr::lag(start, 1), start)) %>%
mutate(id = as.numeric(rownames(.))) %>%
mutate(sign = ifelse(Items %in% c("I1", "I3", "I11"), "Total",
ifelse(sign(Amount) >= 0, "Increase", "Decrease"))) %>%
mutate(ofwhich = ifelse(str_detect(Items, "\\."), 1, 0)) %>%
arrange(desc(id)) %>%
mutate(stand = ifelse(sign(Amount) >= 0, end+fact, start+fact)) %>%
mutate(stand = ifelse(Items == "I11", Amount+fact, stand)) %>%
# mutate(Amount = ifelse(!(Exercise %in% c(2018, 2025)) & Items %in% c("I2", "I3"), NA, Amount)) %>%
filter(!is.na(Amount)) %>%
mutate(Items = factor(Items, rev(dimensions_tr[-c(2,3)]), labels = rev(names(dimensions_tr)[-c(2,3)]))) %>%
mutate(id = rev(as.numeric(rownames(.))))
}
chart <-
dt %>%
mutate(id = abs(id - (max(id) + 1))) %>%
mutate(across(c(start, end, id), ~ifelse(ofwhich == 1, 0, .), .names = "{.col}1")) %>%
mutate(across(c(start, end, id), ~ifelse(ofwhich != 1, 0, .), .names = "{.col}2")) %>%
ggplot(aes(x = Items)) +
geom_rect(aes(
xmin = id1 - .45, xmax = id1 + .45, ymin = end1, ymax = start1,
fill = factor(sign, c("Total", "Increase", "Decrease"))
)) +
geom_rect(aes(xmin = id2 - .45, xmax = id2 + .45, ymin = end2, ymax = start2,
fill = factor(sign, c("Total", "Increase", "Decrease"))
), alpha = 0.6, show.legend = FALSE) +
geom_hline(yintercept = 0, linetype = "dotted", colour = "#7e878e") +
geom_text(aes(x = id, y = stand, label = round(Amount, digits = 2)), size = 3) +
coord_flip() +
theme_classic() +
theme(
axis.title.x = element_text(vjust = 1),
axis.text.y = element_blank(),
text = element_text(size = 12, family = font_name),
legend.position = "bottom",
panel.grid.major = element_blank(),
panel.grid.minor = element_blank(),
strip.background = element_blank(),
legend.title = element_blank(),
) +
labs(
x = "",
y = "% Starting REAs",
caption = "REAs: Risk exposure amounts. Dividends: Amount of Dividends Paid after MDA Related Adjustments."
) +
scale_fill_manual("", values = palette) +
guides(
fill = guide_legend(title.position = "top", order = 1, override.aes = list(alpha = 1, colour = NA))
)
ggplotly(chart, tooltip = "text")
}
## REA: Risk exposure amounts
## NFCI: Net Fee and Commission Income
## Dividends: Amount of Dividends Paid after MDA Related Adjustments
## Capital depletion tables
## EBA ST Resuls
cap_dep = function(data_tr = NULL, data_fl = NULL, period = NA, scenario = NA, exercise = NA, bank = NULL, iso = NULL){
# data_tr = original_data_tr
# data_fl = original_data_fl
# period = "Year 1"
# scenario = "Adverse"
# exercise = 2025
# bank = "Erste Group"
# iso = "Austria"
if (!is.null(bank)) {
bank_id = unique(data_tr[data_tr$Name == bank, "Bank_ID"]$Bank_ID)
data_tr <- data_tr %>%
filter(Bank_ID == bank_id)
data_fl <- data_fl %>%
filter(Bank_ID == bank_id)
} else if (!is.null(iso)) {
data_tr <- data_tr %>%
filter(ISO2 == iso) %>%
mutate(Bank_ID = 1) %>%
mutate(Name = ISO2)
data_fl <- data_fl %>%
filter(ISO2 == iso) %>%
mutate(Bank_ID = 1) %>%
mutate(Name = ISO2)
} else if(is.null(iso) & is.null(bank)){
data_tr <- data_tr %>%
mutate(Bank_ID = 1) %>%
mutate(ISO2 = 1) %>%
mutate(Name = "Systemwide")
data_fl <- data_fl %>%
mutate(Bank_ID = 1) %>%
mutate(ISO2 = 1) %>%
mutate(Name = "Systemwide")
}
depletion_transitional = data_tr %>%
filter(Items %in% c("I1", "I3", "I11"),
Exercise == exercise,
rel_period %in% c("Realised", str_remove_all(period, "\\s{0,}")),
Scenario %in% c("Actual", scenario)
) %>%
pivot_wider(names_from = Items, values_from = Amount) %>%
group_by(ISO2, Bank_ID) %>%
mutate(I11 = dplyr::lead(I11)) %>%
ungroup() %>%
mutate(I3 = ifelse(I1 == I3, NA, I3)) %>%
mutate(depletion = (I11-I1)) %>%
mutate(depletion_restated = (I11-I3)) %>%
dplyr::select(-c(I1, I3, I11)) %>%
pivot_longer(-c(ISO2, Name, Bank_ID, Exercise, Period, Scenario, rel_period), names_to = "Item", values_to = "Depletion") %>%
filter(!is.na(Depletion)) %>%
mutate(Period = "Transitional") %>%
dplyr::select(Name, Period, Item, Depletion) %>%
rename(Constituent = Name, Status = Item)
depletion_fullyloaded = data_fl %>%
filter(Items %in% c("J1.2", "J1.3", "J12"),
Exercise == exercise,
rel_period %in% c("Realised", str_remove_all(period, "\\s{0,}")),
Scenario %in% c("Actual", scenario)
) %>%
pivot_wider(names_from = Items, values_from = Amount) %>%
group_by(ISO2, Bank_ID) %>%
mutate(J12 = dplyr::lead(J12)) %>%
ungroup() %>%
mutate(J1.3 = ifelse(J1.2 == J1.3, NA, J1.3)) %>%
mutate(depletion = (J12-J1.2)) %>%
mutate(depletion_restated = (J12-J1.3)) %>%
dplyr::select(-c(J1.2, J1.3, J12)) %>%
pivot_longer(-c(ISO2, Name, Bank_ID, Exercise, Period, Scenario, rel_period), names_to = "Item", values_to = "Depletion") %>%
filter(!is.na(Depletion)) %>%
mutate(Period = "Fully-Loaded") %>%
dplyr::select(Name, Period, Item, Depletion) %>%
rename(Constituent = Name, Status = Item)
final_bank_table = rbind(depletion_transitional, depletion_fullyloaded) %>%
mutate(Status = ifelse(str_detect(Status, "restated"), "Restated", "Non-Restated")) %>%
pivot_wider(names_from = Status, values_from = Depletion)
if(exercise < 2016){
final_bank_table = final_bank_table %>%
filter(Period == "Transitional")
}
return(final_bank_table)
}
restatement_dep = function(data = NULL, bank = NULL, iso = NULL, FL = F){
# data = data_crr
# bank = "Erste Group"
# iso = "Austria"
if (!is.null(bank)) {
bank_id = unique(data[data$Name == bank, "Bank_ID"]$Bank_ID)
data <- data %>%
filter(Bank_ID == bank_id)
} else if (!is.null(iso)) {
data <- data %>%
filter(ISO2 == iso) %>%
mutate(Bank_ID = 1) %>%
mutate(Name = ISO2)
} else if(is.null(iso) & is.null(bank)){
data <- data %>%
mutate(Bank_ID = 1) %>%
mutate(ISO2 = 1) %>%
mutate(Name = "Systemwide")
}
depletion_res = data %>%
filter(str_detect(Item, "A1|A5")) %>%
pivot_wider(names_from = Item, values_from = Amount) %>%
mutate(depletion_tr = A5_t-A1_t) %>%
mutate(depletion_fl = A5_f-A1_f) %>%
pivot_longer(-c(Name, Bank_ID, ISO2, Exercise, matches("A1|A5")), names_to = "Period", values_to = "Adjustment") %>%
dplyr::select(Name, Period, Adjustment) %>%
mutate(Period = ifelse(str_detect(Period, "_tr"), "Impact - Transitional", "Impact - Fully-Loaded")) %>%
pivot_wider(names_from = Period, values_from = Adjustment)
if(FL == T){
depletion_res = depletion_res %>%
dplyr::select(-`Impact - Transitional`)
}else if(FL == F){
depletion_res = depletion_res %>%
dplyr::select(-`Impact - Fully-Loaded`)
}
if (!is.null(bank)) {
depletion_res = depletion_res %>%
rename(Bank = Name)
} else if (!is.null(iso)) {
depletion_res = depletion_res %>%
rename(Country = Name)
} else if(is.null(iso) & is.null(bank)){
depletion_res = depletion_res %>%
rename(System = Name)
}
return(depletion_res)
}
